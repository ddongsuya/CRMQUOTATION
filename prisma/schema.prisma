// Chemon Quotation — Prisma schema (PostgreSQL — Neon, 로컬·배포 공용)
//
// Catalog data (TestItem / GuidelineBlock / ModalityPreset) seeds from JSON files
// under data/. The DB persists operational data (users + quotes) AND, via DataBlob,
// any master-data edited at runtime so admin edits survive on serverless (read-only FS).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
// Auth
// ─────────────────────────────────────────────────────────

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  name          String
  role          String    @default("user")   // user / admin / (CRM: MEMBER·TEAM_LEAD·CENTER_LEAD·ADMIN)
  passwordHash  String
  createdAt     DateTime  @default(now())
  quotes        Quote[]

  // ─── CRM: 조직 계층 + 소유 ───
  team          Team?     @relation(fields: [teamId], references: [id])
  teamId        Int?
  center        Center?   @relation(fields: [centerId], references: [id])
  centerId      Int?
  companies     Company[]
  deals         Deal[]
  notes         Note[]
  events        CalendarEvent[]

  @@index([teamId])
  @@index([centerId])
}

// ─────────────────────────────────────────────────────────
// CRM — 조직 계층 (요구 #2). role(User.role)로 조회범위 확장.
// ─────────────────────────────────────────────────────────
model Center {
  id        Int      @id @default(autoincrement())
  name      String
  teams     Team[]
  users     User[]
  targets   Target[]
  createdAt DateTime @default(now())
}

// 수주 목표 (관리자 대시보드 목표 게이지·달성률). centerId=null → 전사 목표.
model Target {
  id        Int      @id @default(autoincrement())
  center    Center?  @relation(fields: [centerId], references: [id], onDelete: Cascade)
  centerId  Int?
  period    String                                  // 기간 키: "2026H1" · "2026Q1" · "2026"
  amount    Float                                   // 목표 수주금액(원)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([centerId, period])
  @@index([centerId])
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String
  center    Center?  @relation(fields: [centerId], references: [id])
  centerId  Int?
  users     User[]
  createdAt DateTime @default(now())

  @@index([centerId])
}

// ─────────────────────────────────────────────────────────
// CRM — 고객사 → 의뢰자 → 안건 (Phase 1)
// ─────────────────────────────────────────────────────────
model Company {
  id          Int       @id @default(autoincrement())
  owner       User      @relation(fields: [ownerId], references: [id])
  ownerId     Int
  name        String
  bizRegNo    String?                          // 사업자등록번호
  industry    String?
  address     String?
  isNewClient Boolean   @default(true)          // 첫 거래 여부 (등록 완료 시 false)
  memo        String?
  contacts    Contact[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([ownerId])
}

model Contact {
  id        Int      @id @default(autoincrement())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId Int
  name      String
  email     String?
  phone     String?
  position  String?                            // 직책
  memo      String?
  deals     Deal[]
  notes     Note[]
  events    CalendarEvent[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model Deal {
  id                   Int       @id @default(autoincrement())
  owner                User      @relation(fields: [ownerId], references: [id])
  ownerId              Int
  contact              Contact   @relation(fields: [contactId], references: [id])
  contactId            Int
  title                String
  modality             String?
  indication           String?                 // 적응증
  clinicalDesign       String?                 // 임상 예정 디자인 메모
  submissionTarget     String?                 // 제출처 (MFDS/US FDA/EMA…)
  reportLanguage       String    @default("KO") // KO / EN
  translationRequested Boolean   @default(false)
  stage                String    @default("INQUIRY") // INQUIRY·QUOTE·INTAKE·CONTRACT·STUDY·INVOICE·DONE
  status               String    @default("ACTIVE")  // ACTIVE·WON·LOST
  lostReason           String?
  quotes               Quote[]
  contract             Contract?
  studies              Study[]
  changeQuotes         ChangeQuote[]
  notes                Note[]
  events               CalendarEvent[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([ownerId])
  @@index([contactId])
}

// ─────────────────────────────────────────────────────────
// CRM — 계약 / 지급회차 / 시험추적 / 변경견적 (Phase 2)
// ─────────────────────────────────────────────────────────
model Contract {
  id               Int           @id @default(autoincrement())
  deal             Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId           Int           @unique
  quoteId          Int?                                   // 기반 견적
  status           String        @default("DRAFT")        // DRAFT·SENT·REVIEWED·APPROVED·SIGNED
  costEstimateSentAt DateTime?                            // 예정원가·세금계산서안분 사업지원팀 송부
  draftSentAt      DateTime?                              // 초안 송부
  approvedAt       DateTime?                              // 초안 승인
  signedAt         DateTime?                              // 최종 날인
  contractNumber   String?                                // 계약번호 (사업지원팀 부여)
  paymentTerms     PaymentTerm[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model PaymentTerm {
  id          Int       @id @default(autoincrement())
  contract    Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId  Int
  seq         Int       @default(1)                       // 회차 순번
  kind        String    @default("ADVANCE")               // ADVANCE(선금)·INTERIM(중도금)·BALANCE(잔금)
  ratio       Float?                                      // 비율(0.5) 또는 amount
  amount      Float?
  condition   String?                                     // 계약체결시·최종보고서안 발행+30일 등
  studyId     Int?                                        // 시험번호별 설정 시
  dueAt       DateTime?
  paidAt      DateTime?

  @@index([contractId])
}

model Study {
  id                  Int       @id @default(autoincrement())
  deal                Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId              Int
  studyNumber         String?                             // 시험번호
  director            String?                             // 시험책임자
  itemName            String?                             // 시험 항목명
  requestSentAt       DateTime?                           // 시험관리팀 접수요청
  intakeCompletedAt   DateTime?                           // 접수완료 안내
  reportDraftDueAt    DateTime?                           // 최종보고서(안) 발행 예정 ★
  reportDraftIssuedAt DateTime?                           // 실제 발행
  invoiceRequestedAt  DateTime?                           // 세금계산서 발행요청
  invoiceIssuedAt     DateTime?                           // 발행 완료
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([dealId])
}

model ChangeQuote {
  id        Int      @id @default(autoincrement())
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId    Int
  studyId   Int?
  kind      String                                       // DEDUCT(감가)·ADD(추가금)
  amount    Float
  reason    String
  quoteId   Int?
  createdAt DateTime @default(now())

  @@index([dealId])
}

// ─────────────────────────────────────────────────────────
// Quotations
// ─────────────────────────────────────────────────────────

model Quote {
  id                  Int        @id @default(autoincrement())
  quoteNumber         String     @unique           // CK-YYYYMMDD-NNN

  // ownership
  user                User?      @relation(fields: [userId], references: [id])
  userId              Int?

  // CRM: 안건 연결 (Phase 1) + 견적 생애주기
  deal                Deal?      @relation(fields: [dealId], references: [id])
  dealId              Int?
  sentAt              DateTime?                    // 견적 송부일
  reviewedAt          DateTime?                    // 의뢰자 검토일
  accepted            Boolean?                     // 진행 수락 여부

  // customer
  customerName        String?
  customerCompany     String?
  customerEmail       String?

  // project / modality
  projectName         String
  substanceName       String?
  modality            String
  priceStandard       String     @default("MFDS")  // MFDS / OECD

  // plan snapshot (free-form JSON: route/durations/phase/species/addons/categories/tk)
  planJson            String?

  // settings
  excipientCount      Int        @default(0)
  currency            String     @default("KRW")   // KRW / USD
  exchangeRate        Float?
  discountRate        Float      @default(0)        // 0.0 ~ 1.0

  // lifecycle
  status              String     @default("DRAFT") // DRAFT / ISSUED / SENT / ACCEPTED / REJECTED
  issuedAt            DateTime?
  validUntil          DateTime?

  // calculated snapshot (so we can render the same totals later regardless of catalog drift)
  totalBeforeDiscount Float?
  totalAfterDiscount  Float?
  vatAmount           Float?
  grandTotal          Float?

  items               QuoteItem[]

  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@index([userId])
  @@index([status])
  @@index([dealId])
}

model QuoteItem {
  id               Int      @id @default(autoincrement())
  quote            Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId          Int

  // Reference to TestItem in JSON catalog — snapshot fields preserve display values
  testItemKey      String
  testNameSnapshot String
  adminRouteSnap   String?
  category         String?
  tag              String?

  unitPrice        Float                       // 실제 적용된 가격 (override 적용 후)
  quantity         Int      @default(1)
  subtotal         Float

  source           String   @default("preset") // preset / manual
  priority         String?                     // 필수 / 권장 / 옵션
  displayOrder     Int      @default(0)

  // ─── Phase C-1: 사용자 직접 입력 (override) ─────────────────────────
  // 비임상시험 특유의 변수 다양성 대응. null = override 없음 (자동값 사용).
  // 명시적 0 도 유효한 값 (예: unitPriceOverride=0 → 무료 옵션, studyWeeksOverride=0 → 단회).
  // 견적 재현 시 unitPrice 만으로 충분하나, 어떤 값이 수동인지 추적 위해 별도 저장.
  unitPriceOverride     Float?   // null = pickPrice() 자동값 사용
  studyWeeksOverride    Int?     // null = test item 의 studyWeeks 사용 (F-1)
  hamryangCountOverride Int?     // null = hamryangCountForWeeks() 자동 계산
  customNote            String?  // 자유 메모 (견적서 비고란 출력)

  @@index([quoteId])
}

// ─────────────────────────────────────────────────────────
// Master-data overlay (runtime-edited catalog/templates/knowledge)
// ─────────────────────────────────────────────────────────
// One row per logical dataset (key = 'test_items', 'quote_templates',
// 'modality_templates', 'knowledge:guidelines', …). `json` holds the whole
// array/object — same shape the file-backed editors already write. When a row
// exists it overrides the bundled JSON seed; absent → loader falls back to file.
model DataBlob {
  key       String   @id
  json      Json
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────
// CRM — 기록(미팅·상담) / 일정(캘린더·알람) (Phase 3)
// ─────────────────────────────────────────────────────────
model Note {
  id         Int      @id @default(autoincrement())
  owner      User     @relation(fields: [ownerId], references: [id])
  ownerId    Int
  contact    Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  contactId  Int?
  deal       Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  dealId     Int?
  type       String   @default("MEMO")            // MEETING·CALL·MEMO
  title      String?
  body       String
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([ownerId])
  @@index([contactId])
  @@index([dealId])
}

model CalendarEvent {
  id        Int       @id @default(autoincrement())
  owner     User      @relation(fields: [ownerId], references: [id])
  ownerId   Int
  contact   Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  contactId Int?
  deal      Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  dealId    Int?
  title     String
  type      String    @default("MEETING")         // MEETING·DEADLINE·MILESTONE·REMINDER
  startAt   DateTime
  endAt     DateTime?
  allDay    Boolean   @default(true)
  done      Boolean   @default(false)
  source    String    @default("MANUAL")          // MANUAL·AUTO
  createdAt DateTime  @default(now())

  @@index([ownerId])
  @@index([startAt])
}
